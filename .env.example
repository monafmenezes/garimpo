# ── Telegram ────────────────────────────────────────────────
# 1. Fale com o @BotFather no Telegram, mande /newbot e copie o token.
TELEGRAM_BOT_TOKEN=123456789:AA********************************
# 2. Seu chat id: fale com o @userinfobot que ele te devolve o número.
TELEGRAM_CHAT_ID=123456789

# ── Opcionais ───────────────────────────────────────────────
# Caminho do banco (padrão já serve).
# DB_PATH=./data/garimpo.db
# Rodar o navegador com interface (debug local). Em produção, deixe false/vazio.
# HEADFUL=true
# Rodar só uma vez e sair (útil pra testar ou usar com cron externo).
# RUN_ONCE=true
